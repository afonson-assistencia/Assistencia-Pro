{
  "entities": {
    "customers": {
      "title": "Customer",
      "description": "A customer of the technical assistance shop",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the customer" },
        "phone": { "type": "string", "description": "WhatsApp number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone"]
    },
    "serviceOrders": {
      "title": "Service Order",
      "description": "A repair request for a mobile device",
      "type": "object",
      "properties": {
        "customerId": { "type": "string", "description": "Reference to the customer" },
        "customerName": { "type": "string", "description": "Denormalized customer name for easier listing" },
        "customerPhone": { "type": "string", "description": "Denormalized customer phone for easier listing" },
        "model": { "type": "string", "description": "Device model" },
        "services": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of selected services"
        },
        "problem": { "type": "string", "description": "Reported issue" },
        "entryDate": { "type": "string", "format": "date-time" },
        "deadline": { "type": "string", "format": "date-time" },
        "warrantyDays": { "type": "integer", "description": "Number of warranty days" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "ready", "delivered", "cancelled"] },
        "notes": { "type": "string" },
        "totalValue": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "model", "problem", "entryDate", "status"]
    },
    "products": {
      "title": "Product",
      "description": "An accessory or part for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "integer" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock"]
    },
    "sales": {
      "title": "Sale",
      "description": "A record of a product sale",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "integer" },
        "totalValue": { "type": "number" },
        "discount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "quantity", "totalValue", "date"]
    },
    "expenses": {
      "title": "Expense",
      "description": "A business expense (rent, parts, etc.)",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "value": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["description", "value", "date"]
    },
    "users": {
      "title": "User",
      "description": "System user (admin or staff)",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "settings": {
      "title": "Business Settings",
      "description": "Global settings for the business",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logoUrl": { "type": "string" }
      },
      "required": ["name"]
    },
    "categories": {
      "title": "Inventory Category",
      "description": "A category for inventory products",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "deliveryLocations": {
      "title": "Delivery Location",
      "description": "A predefined location for deliveries with a fixed value",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "value": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "value"]
    },
    "deliveryRuns": {
      "title": "Delivery Run",
      "description": "A delivery made by a motoboy",
      "type": "object",
      "properties": {
        "motoboyId": { "type": "string", "description": "ID of the motoboy (from motoboys collection)" },
        "motoboyName": { "type": "string" },
        "locationId": { "type": "string" },
        "locationName": { "type": "string" },
        "value": { "type": "number", "description": "Unit value of the delivery" },
        "quantity": { "type": "integer", "description": "Number of runs to this location" },
        "totalValue": { "type": "number", "description": "value * quantity" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["motoboyId", "locationId", "date", "status", "quantity", "totalValue"]
    },
    "motoboys": {
      "title": "Motoboy",
      "description": "A delivery person registered by name",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "shoppingList": {
      "title": "Shopping List Item",
      "description": "An item that needs to be purchased for inventory replenishment",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "quantity": { "type": "integer" },
        "productId": { "type": "string", "description": "Optional reference to an existing product" },
        "bought": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "quantity", "bought"]
    }
  },
  "firestore": {
    "/customers": { "schema": "customers", "description": "Collection of customers" },
    "/serviceOrders": { "schema": "serviceOrders", "description": "Collection of repair orders" },
    "/products": { "schema": "products", "description": "Collection of products for sale" },
    "/sales": { "schema": "sales", "description": "Collection of sales records" },
    "/expenses": { "schema": "expenses", "description": "Collection of business expenses" },
    "/users": { "schema": "users", "description": "Collection of system users" },
    "/settings": { "schema": "settings", "description": "Collection of business settings" },
    "/categories": { "schema": "categories", "description": "Collection of inventory categories" },
    "/deliveryLocations": { "schema": "deliveryLocations", "description": "Collection of delivery locations" },
    "/deliveryRuns": { "schema": "deliveryRuns", "description": "Collection of delivery runs" },
    "/motoboys": { "schema": "motoboys", "description": "Collection of motoboys" },
    "/shoppingList": { "schema": "shoppingList", "description": "Collection of items to buy" }
  }
}
