rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && 
         request.auth.token.email.lower() == "afonsocnj@gmail.com") ||
        (request.auth.token.email != null && 
         request.auth.token.email.lower() == "admintec@gmail.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Validate that the document contains only the allowed fields
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /serviceOrders/{orderId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /deliveryLocations/{locationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /motoboys/{motoboyId} {
      allow read: if true; // Allow anyone to check if a motoboy name exists during login
      allow write: if isAdmin();
    }

    match /deliveryRuns/{runId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (resource.data.motoboyId == request.auth.uid || request.auth.token.role == 'motoboy') && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /test/{docId} {
      allow read: if true;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
