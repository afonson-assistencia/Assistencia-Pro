rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && 
         (request.auth.token.email.lower() == "admintec@gmail.com" || request.auth.token.email.lower() == "afonsocnj@gmail.com")) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Validate that the document contains only the allowed fields
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Validate theme object
    function isValidTheme(theme) {
      return theme is map &&
             theme.primaryColor is string &&
             theme.backgroundColor is string &&
             theme.textColor is string &&
             theme.buttonColor is string &&
             theme.buttonTextColor is string;
    }

    // Validate storefront data
    function isValidStorefront(data) {
      return hasOnlyAllowedFields(['name', 'slug', 'description', 'whatsappNumber', 'logoUrl', 'theme', 'productIds', 'active', 'ownerId', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.slug is string && data.slug.size() > 0 && data.slug.size() < 50 &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000)) &&
             (!('whatsappNumber' in data) || (data.whatsappNumber is string && data.whatsappNumber.size() < 20)) &&
             (!('logoUrl' in data) || (data.logoUrl is string && data.logoUrl.size() < 500)) &&
             data.active is bool &&
             data.productIds is list &&
             isValidTheme(data.theme);
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /access_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /serviceOrders/{orderId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /deliveryLocations/{locationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /motoboys/{motoboyId} {
      allow read: if true; // Allow anyone to check if a motoboy name exists during login
      allow write: if isAdmin();
    }

    match /deliveryRuns/{runId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (resource.data.motoboyId == request.auth.uid || request.auth.token.role == 'motoboy') && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /shoppingList/{itemId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /storefronts/{storefrontId} {
      allow read: if true;
      allow create: if isAdmin() && isValidStorefront(request.resource.data);
      allow update: if isAdmin() && isValidStorefront(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /test/{docId} {
      allow read: if true;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
